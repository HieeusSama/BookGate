@model BookGate.Application.DTOs.BookDTO
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
    bool isEdit = ViewBag.IsEdit ?? false;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Gate - @(isEdit ? "Chỉnh sửa sách" : "Thêm sách")</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
            color: #1e272e;
        }

        /* --- Header Styles --- */
        .navbar-custom {
            padding: 20px 0;
            background-color: #fff;
            margin-bottom: 50px;
        }

        .search-box {
            color: #808e9b;
            font-size: 0.95rem;
        }

            .search-box input {
                border: none;
                outline: none;
                font-size: 0.95rem;
                width: 220px;
            }

        .brand-logo {
            font-weight: 800;
            font-size: 1.25rem;
            color: #000;
            text-decoration: none;
        }

        .user-profile {
            background-color: #f1f2f6;
            padding: 5px 15px 5px 5px;
            border-radius: 50px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .user-avatar {
            width: 30px;
            height: 30px;
            background-color: #a4b0be;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        /* --- Form Styles --- */
        .form-custom-control {
            border-radius: 12px;
            border: 1px solid #2f3542;
            box-shadow: none;
        }

            .form-custom-control:focus {
                border-color: #009dff;
                box-shadow: 0 0 0 0.25rem rgba(0, 157, 255, 0.1);
            }

        .form-floating > label {
            font-weight: 600;
            color: #2f3542;
            padding: 12px 15px;
        }

        .form-floating > .form-control, .form-floating > .form-select {
            padding-top: 25px;
            padding-bottom: 5px;
            font-weight: 500;
        }

        /* --- Button Styles --- */
        .btn-blue {
            background-color: #009dff;
            color: white;
            border-radius: 25px;
            padding: 10px 28px;
            font-weight: 500;
            border: none;
            transition: 0.2s;
        }

            .btn-blue:hover {
                background-color: #0081d6;
                color: white;
            }

        .btn-gray {
            background-color: #a4b0be;
            color: white;
            border-radius: 25px;
            padding: 10px 28px;
            font-weight: 500;
            border: none;
            transition: 0.2s;
            text-decoration: none;
        }

            .btn-gray:hover {
                background-color: #747d8c;
                color: white;
            }

        /* --- Image Placeholder --- */
        .cover-upload-circle {
            width: 220px;
            height: 220px;
            background-color: #a4b0be;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            overflow: hidden;
            margin-bottom: 20px;
        }

            .cover-upload-circle i {
                font-size: 4.5rem;
            }

            .cover-upload-circle img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        /* --- Footer Styles --- */
        footer {
            margin-top: 80px;
            padding: 60px 0 30px;
            border-top: 1px solid #f1f2f6;
        }
    </style>
</head>
<body>

    <div class="container">

        <header class="navbar-custom d-flex justify-content-between align-items-center">
            <div class="search-box d-flex align-items-center gap-2">
                <i class="bi bi-search fs-5 text-dark"></i>
                <input type="text" placeholder="Tìm kiếm sách...">
            </div>

            <a asp-controller="Book" asp-action="Index" class="brand-logo">Book Gate</a>

            <div class="d-flex align-items-center gap-3">
                <div class="user-profile">
                    <div class="user-avatar"><i class="bi bi-person-fill"></i></div>
                    <span>Book</span>
                </div>
                <i class="bi bi-bell fs-5"></i>
            </div>
        </header>

        <form asp-controller="Book" asp-action="@(isEdit ? "Edit" : "Create")" method="post" enctype="multipart/form-data">

            <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

            <div class="row pe-lg-5">
                <div class="col-lg-7">
                    @if (isEdit)
                    {
                        <div class="form-floating mb-3">
                            <input asp-for="BookId" class="form-control form-custom-control bg-light" placeholder="Mã sách" readonly>
                            <label asp-for="BookId">Mã sách</label>
                        </div>
                    }

                    <div class="form-floating mb-3">
                        <input asp-for="Title" class="form-control form-custom-control" placeholder="Tên sách" required>
                        <label asp-for="Title">Tên sách</label>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <div class="form-floating">
                                <input asp-for="Author" class="form-control form-custom-control" placeholder="Tác giả" required>
                                <label asp-for="Author">Tác giả</label>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-floating">
                                <select asp-for="PublisherId" asp-items="ViewBag.PublisherList" class="form-select form-custom-control">
                                    <option value="">-- Chọn Nhà xuất bản --</option>
                                </select>
                                <label asp-for="PublisherId">Nhà xuất bản</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <div class="form-floating">
                                <input asp-for="PublicationDate" type="date" class="form-control form-custom-control" required>
                                <label asp-for="PublicationDate">Ngày xuất bản</label>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-floating">
                                <input asp-for="Genre" class="form-control form-custom-control" placeholder="Thể loại" required>
                                <label asp-for="Genre">Thể loại</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-6">
                            <div class="form-floating">
                                <input asp-for="PurchasePrice" type="number" class="form-control form-custom-control" placeholder="Giá nhập" required>
                                <label asp-for="PurchasePrice">Giá nhập (VNĐ)</label>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-floating">
                                <input asp-for="SellingPrice" type="number" class="form-control form-custom-control" placeholder="Giá bán" required>
                                <label asp-for="SellingPrice">Giá bán (VNĐ)</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-5">
                        <button type="submit" class="btn btn-blue px-4">@(isEdit ? "Lưu thay đổi" : "Thêm sách mới")</button>
                        <a asp-controller="Book" asp-action="Index" class="btn btn-gray px-4">Hủy bỏ</a>
                    </div>
                </div>

                <div class="col-lg-1"></div>

                <div class="col-lg-4 d-flex flex-column align-items-center pt-2">
                    <div class="cover-upload-circle" id="imagePreviewContainer">
                        @if (isEdit && !string.IsNullOrEmpty(Model?.FileUrl))
                        {
                            <img src="@Model.FileUrl" alt="Bìa sách" id="coverPreview" />
                        }
                        else
                        {
                            <i class="bi bi-image" id="coverPlaceholder"></i>
                            <img src="" alt="Bìa sách" id="coverPreview" class="d-none" />
                        }
                    </div>

                    <input type="file" name="coverImage" id="coverImage" accept="image/*" class="d-none" onchange="previewImage(event)">
                    <button type="button" class="btn btn-blue mb-2" onclick="document.getElementById('coverImage').click()">Tải ảnh bìa lên</button>

                    <small class="text-muted text-center mt-2">Định dạng hỗ trợ: JPG, PNG.<br>Kích thước tối đa 2MB.</small>

                    <input type="hidden" asp-for="FileUrl" />
                </div>
            </div>
        </form>

        <footer>
            <div class="text-center text-muted" style="font-size: 0.85rem;">
                Copyright © 2026. BookGate.
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function(){
                var output = document.getElementById('coverPreview');
                var placeholder = document.getElementById('coverPlaceholder');
                output.src = reader.result;
                output.classList.remove('d-none');
                if(placeholder) { placeholder.classList.add('d-none'); }
            };
            if(event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }
    </script>
</body>
</html>