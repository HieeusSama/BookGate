@model IEnumerable<BookGate.Application.DTOs.MemberBookDTO>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Gate - Trang chủ</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
            color: #1e272e;
        }

        .navbar-custom {
            padding: 20px 0;
            background-color: #fff;
        }

        .search-box {
            color: #808e9b;
            font-size: 0.95rem;
            cursor: text;
        }

        .brand-logo {
            font-weight: 800;
            font-size: 1.25rem;
            letter-spacing: 0.5px;
            color: #000;
            text-decoration: none;
        }

        .user-action {
            display: flex;
            align-items: center;
            gap: 15px;
            color: #1e272e;
            font-size: 0.95rem;
            font-weight: 500;
        }

        .hero-banner {
            background-color: #e2e8f0;
            height: 280px;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 50px;
            margin-top: 10px;
        }

        .section-header {
            display: flex;
            align-items: baseline;
            margin-bottom: 20px;
        }

            .section-header h5 {
                font-weight: 700;
                font-size: 1rem;
                text-transform: uppercase;
                margin-bottom: 0;
                letter-spacing: 0.5px;
            }

            .section-header small {
                color: #808e9b;
                margin-left: 8px;
                font-size: 0.85rem;
            }

        /* Chỉnh sửa CSS cho Book Card */
        .book-card {
            padding: 10px;
            border-radius: 8px;
            border: 1px solid transparent;
            transition: all 0.2s ease;
            background: #fff;
        }

            .book-card:hover {
                border-color: #e2e8f0;
                box-shadow: 0 4px 15px rgba(0,0,0,0.05);
                transform: translateY(-3px);
            }

        .book-item {
            text-decoration: none;
            color: inherit;
            display: block;
        }

        /* Nút yêu thích */
        .btn-favorite {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: none;
            z-index: 10;
            cursor: pointer;
            transition: all 0.2s;
        }

            .btn-favorite:hover {
                transform: scale(1.1);
            }

            .btn-favorite .bi-heart-fill {
                display: none;
            }

            .btn-favorite:hover .bi-heart {
                display: none;
            }

            .btn-favorite:hover .bi-heart-fill {
                display: inline-block;
            }

        .book-cover {
            background-color: #e2e8f0;
            aspect-ratio: 3/4;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 12px;
            overflow: hidden;
        }

            .book-cover i {
                font-size: 2.5rem;
                color: #cbd5e1;
            }

        .book-title {
            font-weight: 600;
            font-size: 0.95rem;
            line-height: 1.4;
            margin-bottom: 4px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .book-author {
            color: #64748b;
            font-size: 0.8rem;
        }

        .book-publisher {
            color: #a4b0be;
            font-size: 0.75rem;
            margin-bottom: 4px;
        }

        /* Nút Mua */
        .btn-buy {
            font-size: 0.85rem;
            font-weight: 600;
            background-color: #009dff;
            color: white;
            border: none;
            padding: 8px;
            border-radius: 6px;
            transition: background-color 0.2s;
        }

            .btn-buy:hover {
                background-color: #0081d6;
                color: white;
            }

        footer {
            margin-top: 80px;
            padding: 60px 0 30px;
            border-top: 1px solid #f1f2f6;
        }

        .footer-logo i {
            font-size: 2rem;
            color: #1e272e;
        }

        .footer-title {
            font-weight: 700;
            color: #ff7675;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
            text-transform: uppercase;
        }

        .footer-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .footer-links li {
                margin-bottom: 12px;
            }

            .footer-links a {
                color: #1e272e;
                text-decoration: none;
                font-size: 0.9rem;
            }

                .footer-links a:hover {
                    color: #ff7675;
                }
    </style>
</head>
<body>

    <div class="container">
        <header class="navbar-custom d-flex justify-content-between align-items-center">
            <div class="search-box d-flex align-items-center gap-2">
                <i class="bi bi-search fs-5"></i>
                <span class="d-none d-md-inline">Tìm kiếm sách, tác giả...</span>
            </div>

            <a href="/" class="brand-logo">Book Gate</a>

            <div class="user-action">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-person-circle fs-4 text-secondary"></i>
                    <span class ="d-none d-md-inline">Chào, @User.Identity!.Name</span>
                </div>
                <i class="bi bi-bag fs-5 ms-3"></i>
            </div>
        </header>

        <div class="hero-banner">
            <i class="bi bi-image" style="font-size: 4rem; color: #cbd5e1;"></i>
        </div>

        @{
            var sections = new[] {
                new { Title = "SÁCH MỚI CẬP NHẬT", Subtitle = "(Mới nhất)" },
                new { Title = "SÁCH ĐƯỢC ĐỀ XUẤT", Subtitle = "(Random)" }
                };
        }

        @foreach (var item in sections)
        {
            <section class="mb-5">
                <div class="section-header">
                    <h5>@item.Title</h5>
                    <small>@item.Subtitle</small>
                </div>

                <div class="row row-cols-2 row-cols-md-3 row-cols-lg-6 g-3 g-md-4">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var book in Model.Take(6))
                        {
                            <div class="col">
                                <div class="book-card position-relative h-100 d-flex flex-column">

                                    <button class="btn-favorite position-absolute top-0 end-0 m-2 rounded-circle bg-white shadow-sm" title="Thêm vào yêu thích">
                                        <i class="bi bi-heart text-danger fs-6"></i>
                                        <i class="bi bi-heart-fill text-danger fs-6"></i>
                                    </button>

                                    <a href="#" class="book-item flex-grow-1">
                                        <div class="book-cover">
                                            @if (!string.IsNullOrEmpty(book.FileUrl))
                                            {
                                                <img src="@book.FileUrl" alt="@book.Title" style="width: 100%; height: 100%; object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <i class="bi bi-image"></i>
                                            }
                                        </div>

                                        <div class="book-title" title="@book.Title">@book.Title</div>
                                        <div class="book-author">@book.Author</div>
                                        <div class="book-publisher">NXB: @book.PublisherName</div>
                                        <div class="text-danger fw-bold mt-1 fs-6">@book.SellingPrice.ToString("N0") đ</div>
                                    </a>

                                    <button class="btn-buy w-100 mt-3 d-flex justify-content-center align-items-center gap-2">
                                        <i class="bi bi-cart-plus"></i> Chọn mua
                                    </button>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <p class="text-muted fst-italic">Đang cập nhật sách...</p>
                        </div>
                    }
                </div>
            </section>
        }

    </div>

    <footer>
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 pe-lg-5 mb-4 mb-lg-0">
                    <div class="footer-logo mb-3">
                        <i class="bi bi-book"></i>
                    </div>
                    <p class="text-muted" style="font-size: 0.85rem; line-height: 1.6;">
                        Book Gate là nền tảng đọc sách trực tuyến hàng đầu, mang đến cho bạn không gian khám phá tri thức vô tận.
                    </p>
                </div>

                <div class="col-lg-2 d-none d-lg-block"></div>

                <div class="col-6 col-lg-2">
                    <h6 class="footer-title">Khám phá</h6>
                    <ul class="footer-links">
                        <li><a href="#">Về chúng tôi</a></li>
                        <li><a href="#">Blog</a></li>
                    </ul>
                </div>

                <div class="col-6 col-lg-2">
                    <h6 class="footer-title">Trợ giúp</h6>
                    <ul class="footer-links">
                        <li><a href="#">Hỗ trợ</a></li>
                        <li><a href="#">Liên hệ</a></li>
                    </ul>
                </div>

                <div class="col-12 col-lg-2 mt-4 mt-lg-0">
                    <h6 class="footer-title">Theo dõi</h6>
                    <ul class="footer-links">
                        <li><a href="#"><i class="bi bi-facebook me-2"></i> Facebook</a></li>
                        <li><a href="#"><i class="bi bi-instagram me-2"></i> Instagram</a></li>
                    </ul>
                </div>
            </div>

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-5 pt-4 border-top" style="font-size: 0.8rem; color: #a4b0be;">
                <p class="mb-2 mb-md-0">Copyright © 2026 BookGate. All rights reserved.</p>
                <div class="d-flex gap-3">
                    <a href="#" class="text-decoration-none text-muted">Điều khoản</a>
                    <a href="#" class="text-decoration-none text-muted">Bảo mật</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>